{
  "entities": {
    "RealizationFeedback": {
      "title": "RealizationFeedback",
      "description": "Aggregated reactions and statistics for a specific realization",
      "type": "object",
      "properties": {
        "likesCount": {
          "type": "integer",
          "description": "Number of likes"
        },
        "heartsCount": {
          "type": "integer",
          "description": "Number of heart/love reactions"
        },
        "solidariesCount": {
          "type": "integer",
          "description": "Number of solidarity/care reactions"
        },
        "sadsCount": {
          "type": "integer",
          "description": "Number of sad reactions"
        }
      },
      "required": ["likesCount", "heartsCount", "solidariesCount", "sadsCount"]
    },
    "RealizationComment": {
      "title": "RealizationComment",
      "description": "A comment left by a visitor on a specific realization",
      "type": "object",
      "properties": {
        "authorName": {
          "type": "string",
          "maxLength": 50,
          "description": "Name of the person commenting"
        },
        "content": {
          "type": "string",
          "maxLength": 500,
          "description": "The comment message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/realizations_feedback/{realizationId}": {
      "schema": "RealizationFeedback",
      "description": "Reactions and stats for a specific realization"
    },
    "/realizations_feedback/{realizationId}/comments/{commentId}": {
      "schema": "RealizationComment",
      "description": "Individual comments on a specific realization"
    }
  }
}
